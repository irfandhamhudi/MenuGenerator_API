    "seed:small": "tsx src/seed-small.ts"
  },
  "dependencies": {
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "cookie-parser": "^1.4.6",
    "mongoose": "^8.8.0",
    "jsonwebtoken": "^9.0.2",
    "dotenv": "^16.4.5",
    "bcryptjs": "^2.4.3",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "cloudinary": "^1.21.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/cookie-parser": "^1.4.7",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.3",
    "tsx": "^4.19.0"
